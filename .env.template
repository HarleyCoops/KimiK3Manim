# Moonshot AI / Kimi API Configuration
# Copy to .env and fill in your values.
# Get your API key from: https://platform.kimi.ai/

MOONSHOT_API_KEY=sk-your-key-here

# Model Configuration
# kimi-k3: flagship, used by the whole K3 agent swarm including the Manim Coder
KIMI_MODEL=kimi-k3
KIMI_MODEL_CODE=kimi-k3

# K3 reasoning effort (thinking is always on for kimi-k3; only "max" at launch)
KIMI_REASONING_EFFORT=max

# Optional: Tool Configuration
KIMI_USE_TOOLS=true

# Legacy K2-only thinking toggle; ignored by kimi-k3
# KIMI_ENABLE_THINKING=heavy
